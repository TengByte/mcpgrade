{
  "name": "mcpgrade",
  "version": "0.1.0",
  "description": "Lighthouse for MCP servers \u2014 lint your MCP server for agent usability, not just spec compliance",
  "type": "module",
  "bin": {
    "mcpgrade": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lint",
    "agent",
    "llm",
    "tools",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "gpt-tokenizer": "^2.8.0",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TengByte/mcpgrade.git"
  },
  "homepage": "https://github.com/TengByte/mcpgrade#readme",
  "bugs": {
    "url": "https://github.com/TengByte/mcpgrade/issues"
